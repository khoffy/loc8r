extends layout 

block content
    .row.banner 
        .col-12 
            h1 Starcups 
    .row 
        .col-12.col-lg-9 
            .row 
                .col-12.col-md-6 
                    p.rating 
                        i.fas.fa-star
                        i.fas.fa-star
                        i.fas.fa-star
                        i.far.fa-star
                        i.far.fa-star
                    p 125 High Street, Reading, RG6 1PS
                    .card.card-primary 
                        .card-block 
                            h2.card-title Heures d'ouverture
                            p.card-text Lundi - Vendredi : 7h - 19h
                            p.card-text Samedi : 8h - 17h
                            p.card-text Dimanche : fermé 
                    .card.card-primary 
                        .acard-block 
                            h2.card-title Consommations 
                            span.badge.badge-warning 
                                i.fa.fa-check 
                                | &nbsp;Boissons chaudes 
                            | &nbsp;
                            span.badge.badge-warning 
                                i.fa.fa-check 
                                | &nbsp;Nourriture 
                            | &nbsp;
                            span.badge.badge-warning 
                                i.fa.fa-check 
                                | &nbsp;Wifi premium 
                            | &nbsp;
                .col-12.col-md-6.location-map 
                    .card.card-primary 
                        .card-block 
                            h2.card-title Carte de localisation
                            img.img-fluid.rounded(src='https://maps.googleapis.com/maps/api/staticmap?center=51.455041,-0.9690884&zoom=17&size=400x350&sensor=false&markers=51.455041,-0.9690884&scale=2&key=AIzaSyA1ypiCExaXbnLd_NQ1VwiP2JRr42XdHQ4')
                            //img.img-fluid.rounded(src='/images/Agnes_gru.png')
    .row 
        .col-12 
            .card.card-primary.review-card 
                .card-block 
                    a.btn.btn-primary.float-end(href='/location/review/new') Add review 
                    h2.card-title Commentaires des clients 
                    .row.review 
                        .col-12.no-gutters.review-header 
                            span.rating 
                                i.fas.fa-star
                                i.fas.fa-star
                                i.fas.fa-star
                                i.fas.fa-star
                                i.far.fa-star
                            span.reviewAuthor &nbsp; &nbsp; Simon Holmes 
                            small.reviewTimestamp &nbsp; &nbsp; 25 October 2021
                        .col-12 
                            p Quel agréable endroit !
                    .row.review 
                        .col-12.no-gutters.review-header 
                            span.rating 
                                i.fas.fa-star
                                i.fas.fa-star
                                i.fas.fa-star
                                i.far.fa-star
                                i.far.fa-star
                            span.reviewAuthor &nbsp; &nbsp; Charlie Chaplin 
                            small.reviewTimestamp &nbsp; &nbsp; 23 October 2021
                        .col-12 
                            p C'était cool. Le café n'était pas.
        .col-12.col-lg-3 
            p.lead 
                | Starcups is on Loc8r because it has accessible wifi and space to sit down with your laptop and get some work done.
            p 
                | If you've been and you like it - or if you don't - please leave a review to help other people just like you.